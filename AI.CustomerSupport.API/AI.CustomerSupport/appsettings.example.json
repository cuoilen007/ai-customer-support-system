{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=AI_CustomerSupport;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Key": "replace_with_a_secure_jwt_key_at_least_32_characters_long",
    "Issuer": "AI.CustomerSupport",
    "Audience": "AI.CustomerSupport"
  },
  "AiService": {
    "BaseUrl": "http://localhost:8000"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "SeedOnStartup": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
